# =============================================
# Enduria SIM Configuration
# =============================================
# Copy this file to .env and fill in the required values:
#   cp .env.enduria.example .env

# ----- Required: Shared with Enduria -----
# Must match the values configured in the Enduria SaaS application.
# Use `openssl rand -hex 32` to generate each secret.
NEXTAUTH_SECRET=
INTERNAL_API_SECRET=
ENDURIA_API_URL=http://enduria:9002

# ----- Required: Database -----
DATABASE_URL=postgresql://sim:simdev@db:5432/sim
POSTGRES_USER=sim
POSTGRES_PASSWORD=simdev
POSTGRES_DB=sim
# POSTGRES_PORT=5432

# ----- Required: Encryption -----
# Use `openssl rand -hex 32` to generate each key.
ENCRYPTION_KEY=
API_ENCRYPTION_KEY=

# ----- Required: Application URLs -----
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_SOCKET_URL=ws://localhost:3002
# SOCKET_SERVER_URL=http://realtime:3002  # Internal service-to-service URL (default works with docker-compose)

# ----- Optional: AI Providers -----
# At least one provider key is needed for AI workflow blocks.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# ----- Optional: Redis -----
# Used for async job queue (background workflows) and realtime pub/sub.
# The docker-compose stack includes a Redis container; this default connects to it.
REDIS_URL=redis://redis:6379
# REDIS_PORT=6379  # Host port mapping (default: 6379)

# ----- Optional: Trigger.dev -----
# SIM uses a fallback chain for background jobs: Trigger.dev -> Redis -> Database.
# By default (with Redis available), SIM uses the Redis-based job queue. Set
# TRIGGER_DEV_ENABLED=true to use Trigger.dev instead (cloud or self-hosted).
#
# TRIGGER_DEV_ENABLED=true
# TRIGGER_PROJECT_ID=                  # Your Trigger.dev project ID (e.g. proj_xxxx)
# TRIGGER_SECRET_KEY=                  # Server-side secret key (starts with tr_dev_ or tr_prod_)
# TRIGGER_API_URL=http://trigger:3040  # For self-hosted Trigger.dev; omit for cloud (defaults to https://api.trigger.dev)
#
# --- Self-Hosting Trigger.dev ---
# Trigger.dev self-hosting requires its own infrastructure:
#   - Webapp container (ghcr.io/triggerdotdev/trigger.dev:v4)
#   - Its own PostgreSQL database (separate from SIM, requires wal_level=logical)
#   - Redis (can share with SIM or use its own)
#   - ElectricSQL for data sync
#   - Supervisor/coordinator for task execution (needs Docker socket access)
#   - Container registry + object storage
#
# Because of this complexity, Trigger.dev is NOT bundled in docker-compose.enduria.yml.
# Options:
#   1. Use Trigger.dev Cloud (https://trigger.dev) -- simplest, just set the env vars above
#   2. Run Trigger.dev self-hosted separately using their official Docker setup:
#      https://github.com/triggerdotdev/docker
#      https://trigger.dev/docs/self-hosting/docker
#   3. Skip Trigger.dev entirely -- SIM falls back to Redis queue automatically

# ----- Optional: Development -----
# Set to true to bypass authentication entirely (anonymous session for all requests).
# Only use behind trusted private networks.
DISABLE_AUTH=false
